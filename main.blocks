ion><value name="sprite"><block type="variables_get" id="k[#cPpLo/TjSH*q);I*C"><field name="VAR" id="n8T;k+FN28dPRJVTdi+?">sprite</field></block></value><value name="vx"><shadow type="spriteSpeedPicker" id="8-jmjm({SW+78PI_Qn83"><field name="speed">0</field></shadow></value><value name="vy"><shadow type="spriteSpeedPicker" id="3Bxemx08{=jIr5,}]E$d"><field name="speed">0</field></shadow></value><next><block type="arcade_story_print_character_text" id="}4~`S=QB=nIu?-}r.j[I"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="KVHy{X+6[K?,+pBG0)jh"><field name="TEXT">Six stones . One mission . No mistakes</field></shadow></value><value name="label"><shadow type="text" id="H3`VvqgrA08:f{)fDubH"><field name="TEXT">Cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="@9D4?[3b4@JJwCjrRjIp"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="b29{0P$=fk08a,3L5@7]"><field name="TEXT">I've mapped the timelines - we can grab them before things go sideways</field></shadow></value><value name="label"><shadow type="text" id="uyreZa_dzP$1!Tv+0+a0"><field name="TEXT">iron man</field></shadow></value><next><block type="arcade_story_print_character_text" id="45`q$acrSx/t:HJSl$SC"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="gg}d{4t7h2U35`yNo@n)"><field name="TEXT">Time travel and stealing cosmic rocks ? I like this</field></shadow></value><value name="label"><shadow type="text" id="),hHlVt50G|@H~Fhb8?6"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id="~;/,bIjq;%7#bw=0p@U%"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="4l[rkpZ=mW=A!0//k9B`"><field name="TEXT">Just don't mess up the timeline beyond repair </field></shadow></value><value name="label"><shadow type="text" id="F`,t9B`,0Gvt..cy_U;U"><field name="TEXT">Cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="2?u||5,Biu1(CNplEP*9"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="(EXv*^B,3%Ayb)q-/PbB"><field name="TEXT">Focus. Tony and I take the mind and time stones . Thor you,re on the power stone , and you take the space and mind stones .</field></shadow></value><value name="label"><shadow type="text" id="U],f6VKTqY%Bi|thcl3+"><field name="TEXT">Cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="qViPVcss$0Zo/2?-[una"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="]Te=Vp:(02{]eda//z9_"><field name="TEXT">Consider it done (;</field></shadow></value><value name="label"><shadow type="text" id="gl:_(o9h5tS7/d.jXNY;"><field name="TEXT">You</field></shadow></value><next><block type="arcade_story_print_character_text" id=":wynIeB~Ap86(27yEd/P"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="21w$%I.YSz%w=Q^DM[Zq"><field name="TEXT">Finally ,a task worthy of my strength</field></shadow></value><value name="label"><shadow type="text" id="]*#{t![%-4gi[JO:omDS"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id="VU%*d.2_`/J%6Bv-mIyS"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="!9TI~nBuOd3fPOI81sC}"><field name="TEXT">Try not to break the universe, point break</field></shadow></value><value name="label"><shadow type="text" id="gjO$,T4awU0*ySH6]p3h"><field name="TEXT">Ironman</field></shadow></value><next><block type="arcade_story_print_character_text" id=";*PAC|eTBm@JDadrKw^$"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="7XvkU8owrv:%e1}BMp$4"><field name="TEXT">We regroup once we have them all . No detours</field></shadow></value><value name="label"><shadow type="text" id="/jG31zI.1Su=+HRE#iTI"><field name="TEXT">cap</field></shadow></value><next><block type="arcade_story_print_character_text" id="Nzo.9EYs+g~|_Dz2[6?k"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="0T9~+!wf:zo$l;Q7Gx/("><field name="TEXT">You have my word.</field></shadow></value><value name="label"><shadow type="text" id="N##K]VT:h+(JzhKpl?ei"><field name="TEXT">Thor</field></shadow></value><next><block type="arcade_story_print_character_text" id="$K[A*okvsL;.OV2iG]${"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="^V9L`=TYMyj1@E=H1@6h"><field name="TEXT">Bet.</field></shadow></value><value name="label"><shadow type="text" id="PayqT#KFBC3S;R|18Uj="><field name="TEXT">You</field></shadow></value><next><block type="arcade_story_print_character_text" id="%tSA`Dy^!8U4RgPV]oly"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="1" _input_init="true"></mutation><value name="text"><shadow type="text" id="XX3+@OLVp33#B-6GXKoj"><field name="TEXT">That's exactly what I was afraid of.</field></shadow></value><value name="label"><shadow type="text" id="TE=Et0L)e(G2-QLOPI`b"><field name="TEXT">Ironman</field></shadow></value><next><block type="game_control_sprite" id="gM:,)a5V,B1ltn8%R|3M"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="sprite"><block type="variables_get" id="Lm:i*Dn^1c},(d+S{3`_"><field name="VAR" id="n8T;k+FN28dPRJVTdi+?">sprite</field></block></value><value name="vx"><shadow type="sprite